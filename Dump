<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>5 Dump & Go Crockpot Dinners | The Cozy Family Kitchen</title>
  <meta name="description" content="5 dump and go crockpot dinners that are easy, cozy, family-friendly, and perfect for busy weeknights." />
  <style>
    :root {
      --bg: #fffaf6;
      --card: #ffffff;
      --text: #2c1d16;
      --muted: #6b5a52;
      --accent: #b64b1f;
      --accent-dark: #8f3917;
      --gold: #f2b544;
      --cream: #f8efe7;
      --border: #ead7c7;
      --shadow: 0 12px 30px rgba(73, 38, 20, 0.10);
      --radius: 22px;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      font-family: Arial, Helvetica, sans-serif;
      background: linear-gradient(180deg, #fffaf6 0%, #fdf4ec 100%);
      color: var(--text);
      line-height: 1.6;
    }

    img {
      max-width: 100%;
      display: block;
      border-radius: 18px;
    }

    .container {
      width: min(1100px, 92%);
      margin: 0 auto;
    }

    .hero {
      background:
        linear-gradient(rgba(39, 22, 16, 0.55), rgba(39, 22, 16, 0.65)),
        url("https://images.unsplash.com/photo-1547592180-85f173990554?auto=format&fit=crop&w=1400&q=80") center/cover no-repeat;
      color: white;
      padding: 80px 0 70px;
      text-align: center;
    }

    .eyebrow {
      display: inline-block;
      background: rgba(242, 181, 68, 0.18);
      border: 1px solid rgba(255,255,255,0.25);
      color: #ffe4b0;
      padding: 8px 14px;
      border-radius: 999px;
      font-size: 0.9rem;
      font-weight: 700;
      letter-spacing: 0.4px;
      margin-bottom: 18px;
    }

    .hero h1 {
      font-size: clamp(2.2rem, 5vw, 4.2rem);
      line-height: 1.05;
      margin: 0 0 16px;
      font-weight: 800;
    }

    .hero p {
      max-width: 760px;
      margin: 0 auto 24px;
      font-size: 1.08rem;
      color: #f8e8de;
    }

    .hero-badges {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 12px;
      margin-top: 22px;
    }

    .badge {
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.18);
      padding: 10px 14px;
      border-radius: 999px;
      font-weight: 700;
      font-size: 0.95rem;
    }

    .intro {
      margin: -28px auto 40px;
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 28px;
      position: relative;
    }

    .intro h2 {
      margin-top: 0;
      font-size: 1.8rem;
      color: var(--accent-dark);
    }

    .pin-note {
      background: #fff3e7;
