      gap: 28px;
      margin-bottom: 40px;
    }

    .recipe-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .recipe-grid {
      display: grid;
      grid-template-columns: 1.1fr 1fr;
    }

    .recipe-image img {
      height: 100%;
      object-fit: cover;
      min-height: 340px;
      border-radius: 0;
    }

    .recipe-content {
      padding: 26px;
      background: linear-gradient(180deg, #fff 0%, #fff8f2 100%);
    }

    .recipe-number {
      display: inline-block;
      background: var(--accent);
      color: white;
      font-weight: 800;
      padding: 8px 14px;
      border-radius: 999px;
      margin-bottom: 12px;
      font-size: 0.95rem;
    }

    .recipe-content h3 {
      margin: 0 0 10px;
      font-size: 1.8rem;
      line-height: 1.15;
      color: #2b160f;
    }

    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin: 12px 0 18px;
    }

    .meta span {
      background: var(--cream);
      color: #6a4a3a;
      padding: 8px 12px;
      border-radius: 999px;
      font-size: 0.9rem;
      font-weight: 700;
    }

    .recipe-content p {
      margin: 12px 0;
    }

    .subhead {
      font-size: 1.04rem;
      font-weight: 800;
      color: var(--accent-dark);
      margin: 18px 0 8px;
    }

    ul, ol {
      padding-left: 20px;
      margin: 8px 0 14px;
    }

    li {
      margin-bottom: 8px;
    }

    .pro-tip {
      background: #fff1e4;
      border: 1px solid #f0c7aa;
      border-radius: 16px;
      padding: 14px 16px;
      margin-top: 14px;
    }

    .pro-tip strong {
      color: var(--accent-dark);
    }

    .notes {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 30px;
      margin: 40px 0;
    }

    .notes-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 22px;
    }

    .note-box {
      background: linear-gradient(180deg, #fff8f1 0%, #fff 100%);
      border: 1px solid var(--border);
      border-radius: 18px;
      padding: 20px;
    }

    .note-box h4 {
      margin-top: 0;
      color: var(--accent-dark);
      font-size: 1.2rem;
    }

    .cta {
      text-align: center;
      background: linear-gradient(135deg, #b64b1f 0%, #8f3917 100%);
      color: white;
      border-radius: 24px;
      padding: 36px 24px;
      margin: 40px 0 70px;
      box-shadow: var(--shadow);
    }

    .cta h2 {
      margin-top: 0;
      font-size: 2rem;
    }

    .cta p {
      max-width: 700px;
      margin: 0 auto 18px;
      color: #ffe7d9;
    }

    .cta a {
      display: inline-block;
      background: var(--gold);
      color: #4a2616;
      text-decoration: none;
      font-weight: 800;
      padding: 14px 22px;
      border-radius: 999px;
      transition: 0.2s ease;
    }

    .cta a:hover {
      transform: translateY(-2px);
    }

    footer {
      text-align: center;
      padding: 22px;
      color: var(--muted);
      font-size: 0.95rem;
    }

    @media (max-width: 860px) {
      .recipe-grid,
      .notes-grid {
        grid-template-columns: 1fr;
      }

      .recipe-image img {
        min-height: 240px;
      }

      .hero {
        padding: 60px 0 50px;
      }

      .intro {
        padding: 22px;
      }

      .recipe-content {
        padding: 22px;
